# Copy to `.env` and fill in. Loaded by app.config.ts at build time.
# NEVER commit the real .env — it is git-ignored.

# Google Sign-In (Web client ID from Firebase console > Authentication > Google)
GOOGLE_WEB_CLIENT_ID=

# AdMob application IDs (from AdMob console). Defaults fall back to Google's
# public TEST ids so the app runs before you have real ones.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# AdMob per-slot ad unit IDs (production builds; dev always uses test ids).
# Create one banner, one interstitial and one rewarded unit per platform.
ADMOB_BANNER_ID_IOS=
ADMOB_BANNER_ID_ANDROID=
ADMOB_INTERSTITIAL_ID_IOS=
ADMOB_INTERSTITIAL_ID_ANDROID=
ADMOB_REWARDED_ID_IOS=
ADMOB_REWARDED_ID_ANDROID=

# Firebase native config files (paths). Generated from your Firebase project.
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICES_PLIST=./GoogleService-Info.plist

# EAS build project id
EAS_PROJECT_ID=
